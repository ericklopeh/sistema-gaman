# App
APP_NAME=Sistema GAMAN
APP_ENV=development
APP_DEBUG=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://192.168.68.123:8010

# Database
POSTGRES_DB=gaman_db
POSTGRES_USER=gaman_user
POSTGRES_PASSWORD=gaman_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://gaman_user:gaman_password@postgres:5432/gaman_db

# Storage
STORAGE_PATH=./storage

# Demo
DEMO_MODE=true

# Horario operativo (captura VENDEDOR)
OPERATING_HOURS_ENABLED=true
OPERATING_HOURS_TIMEZONE=America/Monterrey
OPERATING_HOURS_START=09:00
OPERATING_HOURS_END=18:00
OPERATING_HOURS_DAYS=1,2,3,4,5
OPERATING_DAYS=MON,TUE,WED,THU,FRI

# Telegram — bot delgado + notificaciones backend
TELEGRAM_BOT_TOKEN=
GAMAN_API_URL=http://localhost:8010
