# App
APP_NAME=Sistema GAMAN
APP_ENV=development
APP_DEBUG=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Database
POSTGRES_DB=gaman_db
POSTGRES_USER=gaman_user
POSTGRES_PASSWORD=gaman_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://gaman_user:gaman_password@postgres:5432/gaman_db

# Storage
STORAGE_PATH=/app/storage

# Telegram future
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_PEDIDOS=
TELEGRAM_CHAT_ID_COMPULSA=
